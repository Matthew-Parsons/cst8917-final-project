POST http://localhost:7071/api/validate
Content-Type: application/json

{
  "employee_name": "Eve",
  "employee_email": "eve@company.com",
  "amount": 60,
  "category": "gaming",
  "description": "Controller",
  "manager_email": "manager@company.com"
}

